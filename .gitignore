# ─────────────────────────────────────────────
#  WebhookOS Frontend  —  .gitignore
#  Stack: Next.js 14 · TypeScript · Tailwind
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js build output ──────────────────────
.next/
out/
build/
dist/

# ── Environment variables (NEVER commit these) ─
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local
# Commit .env.example (no secrets) so devs know what vars are needed
!.env.example

# ── Debug / Logs ──────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/

# ── Testing & Coverage ────────────────────────
coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/

# ── TypeScript ────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo
next-env.d.ts

# ── OS generated files ────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Deployment platforms ──────────────────────
.vercel/
.netlify/
.turbo/

# ── Package manager ───────────────────────────
# Project uses npm — keep package-lock.json, ignore others
yarn.lock
pnpm-lock.yaml
.pnpm-store/

# ── Razorpay / Payment keys ───────────────────
# NEXT_PUBLIC_RAZORPAY_KEY_ID goes in .env — never commit
*.key
*.secret

# ── Local dev / backup folders ────────────────
whk-frontend-clean/
*.backup
*.bak

# ── Misc ──────────────────────────────────────
*.pem
.cache/
tmp/
temp/
.temp/
